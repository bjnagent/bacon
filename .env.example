# --- Anthropic (SERVER ONLY — never expose to browser) ---
ANTHROPIC_API_KEY=sk-ant-...
# Current Sonnet (matches the reference artifact). Swappable; verify latest at
# https://docs.anthropic.com/en/api/messages
BACON_MODEL=claude-sonnet-4-6

# --- Gemini (SERVER ONLY) — optional cheaper tier for background bulk work ---
# When set, the nightly sweep's mover/theme scouts, news paraphrasing, and
# tracked-name updates run on Gemini (far cheaper per token, grounded with
# Google Search), with AUTOMATIC fallback to Claude on any error or empty reply.
# User-facing surfaces (morning brief, six-lens analysis, chat) always stay on
# Claude. Leave unset to run everything on Claude as before.
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Cheapest capable default; use gemini-2.5-flash-lite for maximum savings.
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase ---
# These NEXT_PUBLIC_ values are safe to expose (anon key, not service role)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key: SERVER ONLY — used by cron jobs and admin routes ONLY
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Market data (SERVER ONLY) — real movers for the background sweep ---
# The ONLY source of real-time numbers (Bacon never fabricates prices).
# Default provider: Alpha Vantage (free key: https://www.alphavantage.co/support/#api-key)
MARKET_DATA_API_KEY=
# MARKET_DATA_PROVIDER=alphavantage

# Macro backdrop (rates, yield curve, CPI, unemployment, VIX, broad USD index)
# AND the commodity/FX signal feeds (WTI, Brent, nat gas, copper; EUR/USD,
# GBP/USD, USD/JPY) — all via FRED. These commodity/FX levels also price
# Commodity/FX opportunities in the track record's $10K view.
# Free key: https://fredaccount.stlouisfed.org/apikeys . Optional — the macro
# strip and the commodity/FX signals just hide themselves if unset.
FRED_API_KEY=

# Insider-filing clusters via SEC EDGAR (free, no key). SEC's fair-use policy
# asks requesters to identify themselves; set a contact email for the
# User-Agent header. Optional — a generic identifier is used if unset.
# SEC_CONTACT_EMAIL=you@yourdomain.com

# Morning-brief email (optional) — Resend key (free tier: resend.com).
# Without it the email toggle saves but delivery is skipped.
RESEND_API_KEY=
# BRIEF_EMAIL_FROM="Bacon <you@yourdomain.com>"   # defaults to Resend's test sender

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Protects /api/cron/*. Vercel auto-sends it as a Bearer token to cron routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=<generate with: openssl rand -hex 32>
