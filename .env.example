# --- Anthropic (SERVER ONLY — never expose to browser) ---
ANTHROPIC_API_KEY=sk-ant-...
# Verify the exact Sonnet model ID at https://docs.anthropic.com/en/api/messages
BACON_MODEL=claude-sonnet-4-20250514

# --- Supabase ---
# These NEXT_PUBLIC_ values are safe to expose (anon key, not service role)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key: SERVER ONLY — used by cron jobs and admin routes ONLY
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
CRON_SECRET=<generate with: openssl rand -hex 32>
